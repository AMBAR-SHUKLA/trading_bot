# ── Binance Futures Testnet credentials ───────────────────────────────────────
# Register at: https://testnet.binancefuture.com
# Then generate an API key & secret and paste them below.

BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# ── (Optional) Override the base URL ─────────────────────────────────────────
# Default is the Binance Futures Testnet
BINANCE_BASE_URL=https://testnet.binancefuture.com

# ── Networking ────────────────────────────────────────────────────────────────
REQUEST_TIMEOUT=10          # Seconds before a request is considered timed out
MAX_RETRIES=3               # How many times to retry a failed request
RETRY_BACKOFF_FACTOR=1.5    # Exponential back-off multiplier

# ── Risk controls ─────────────────────────────────────────────────────────────
MAX_ORDER_QUANTITY=100.0    # Hard ceiling on any single order quantity
CONFIRM_LARGE_ORDERS=true   # Ask for confirmation if qty >= LARGE_ORDER_THRESHOLD
LARGE_ORDER_THRESHOLD=10.0  # Quantity at which a warning is shown

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO              # DEBUG | INFO | WARNING | ERROR | CRITICAL
